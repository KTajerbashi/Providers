@{
    ViewBag.Title = "Home Page";
}

<main class="main-wrapper">

    <!-- HERO SECTION -->
    <section class="hero-section">

        <div class="container">

            <div class="row align-items-center g-5">

                <!-- LEFT CONTENT -->
                <div class="col-lg-7">

                    <span class="badge bg-primary  p-3 mb-3 rounded-pill">
                        Soap Parser Management
                    </span>

                    <h1 class="hero-title">
                        Modern ASP.NET MVC Dashboard
                    </h1>

                    <p class="hero-subtitle">
                        Build scalable, secure, and high-performance web applications
                        using ASP.NET MVC, Entity Framework, Web API, and modern UI technologies.
                    </p>

                    <div class="hero-actions">

                        <a href="https://asp.net"
                           target="_blank"
                           class="btn-modern">
                            Get Started
                        </a>

                        <a href="#features"
                           class="btn-outline-modern">
                            Explore Features
                        </a>

                    </div>

                </div>

                <!-- RIGHT CARD -->
                <div class="col-lg-5">

                    <div class="glass-card">

                        <h3 class="mb-4">
                            System Overview
                        </h3>

                        <div class="d-flex justify-content-between align-items-center py-3 border-bottom border-secondary">
                            <span class="text-muted">Projects</span>
                            <strong>24</strong>
                        </div>

                        <div class="d-flex justify-content-between align-items-center py-3 border-bottom border-secondary">
                            <span class="text-muted">Active Users</span>
                            <strong>1,248</strong>
                        </div>

                        <div class="d-flex justify-content-between align-items-center py-3">
                            <span class="text-muted">Deployments</span>
                            <strong>96%</strong>
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </section>


    <!-- STATS -->
    <section class="py-section">

        <div class="container">

            <div class="stats-grid">

                <div class="stat-card">
                    <div class="stat-icon">🚀</div>
                    <div class="stat-number">150+</div>
                    <div class="stat-label">Projects Delivered</div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon">⚡</div>
                    <div class="stat-number">99.9%</div>
                    <div class="stat-label">System Performance</div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon">🔒</div>
                    <div class="stat-number">Secure</div>
                    <div class="stat-label">Enterprise Security</div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon">☁️</div>
                    <div class="stat-number">Cloud</div>
                    <div class="stat-label">Azure Integrated</div>
                </div>

            </div>

        </div>

    </section>


    <!-- FEATURES -->
    <section id="features" class="py-section">

        <div class="container">

            <div class="section-header">

                <h2 class="section-title">
                    Platform Features
                </h2>

                <p class="section-subtitle">
                    Everything you need to build modern enterprise-level applications.
                </p>

            </div>

            <div class="features-grid">

                <div class="feature-card">

                    <div class="feature-icon">
                        🚀
                    </div>

                    <h3 class="feature-title">
                        Fast Development
                    </h3>

                    <p class="feature-description">
                        Build scalable web applications rapidly with ASP.NET MVC architecture.
                    </p>

                </div>

                <div class="feature-card">

                    <div class="feature-icon">
                        🔐
                    </div>

                    <h3 class="feature-title">
                        Secure Authentication
                    </h3>

                    <p class="feature-description">
                        Enterprise-grade security with authentication and authorization support.
                    </p>

                </div>

                <div class="feature-card">

                    <div class="feature-icon">
                        📊
                    </div>

                    <h3 class="feature-title">
                        Analytics Dashboard
                    </h3>

                    <p class="feature-description">
                        Monitor statistics, reports, and system activity through modern dashboards.
                    </p>

                </div>

                <div class="feature-card">

                    <div class="feature-icon">
                        🌐
                    </div>

                    <h3 class="feature-title">
                        Responsive UI
                    </h3>

                    <p class="feature-description">
                        Fully responsive and optimized for desktop, tablet, and mobile devices.
                    </p>

                </div>

                <div class="feature-card">

                    <div class="feature-icon">
                        ☁️
                    </div>

                    <h3 class="feature-title">
                        Cloud Ready
                    </h3>

                    <p class="feature-description">
                        Easily deploy applications to Azure and cloud-based infrastructures.
                    </p>

                </div>

                <div class="feature-card">

                    <div class="feature-icon">
                        🧩
                    </div>

                    <h3 class="feature-title">
                        Modular Architecture
                    </h3>

                    <p class="feature-description">
                        Create maintainable applications using reusable components and services.
                    </p>

                </div>

            </div>

        </div>

    </section>

</main>
